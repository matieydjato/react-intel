{
  "name": "react-spec-gen",
  "version": "0.1.2",
  "description": "Auto-generate Vitest + React Testing Library tests and Storybook CSF 3 stories from your React components.",
  "type": "module",
  "bin": {
    "react-spec-gen": "dist/bin/react-intel.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "start": "node dist/bin/react-intel.js",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "keywords": [
    "react",
    "cli",
    "testing",
    "storybook",
    "ast",
    "codegen"
  ],
  "author": "MD",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/matieydjato/react-intel.git"
  },
  "bugs": {
    "url": "https://github.com/matieydjato/react-intel/issues"
  },
  "homepage": "https://github.com/matieydjato/react-intel#readme",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@babel/parser": "^7.24.0",
    "@babel/traverse": "^7.24.0",
    "@babel/types": "^7.24.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "ora": "^9.4.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.20.5",
    "@types/node": "^22.0.0",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.0.2",
    "typescript": "^6.0.3",
    "vitest": "^1.4.0"
  }
}
